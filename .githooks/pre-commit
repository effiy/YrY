#!/usr/bin/env bash
# ── YrY Architecture Pre-Commit Hook ──────────────────────────────────────
#
# Runs architecture compliance check before each commit.
# Blocks commits that drop the architecture grade below B.
#
# Install:  git config core.hooksPath .githooks
# Skip:     git commit --no-verify
# Uninstall: git config --unset core.hooksPath
#
# See: rules/architecture-principles.md, lib/arch-check.mjs
# ──────────────────────────────────────────────────────────────────────────

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
ARCH_CHECK="$ROOT/lib/arch-check.mjs"

# ── Fast path: only check if source files changed ────────────────────────
STAGED=$(git diff --cached --name-only)

# Skip if no relevant files changed (lib/, skills/, agents/, rules/)
if ! echo "$STAGED" | grep -qE '^(lib/|skills/|agents/|rules/)'; then
  exit 0
fi

# ── Run arch check ───────────────────────────────────────────────────────
RESULT=$(node "$ARCH_CHECK" --short 2>&1) || true

# ── Parse result ─────────────────────────────────────────────────────────
GRADE=$(echo "$RESULT" | grep -oE '[ABCD]级' | head -1 | cut -d'级' -f1)

if [ -z "$GRADE" ]; then
  echo "⚠️  arch-check: 无法解析架构等级，允许提交（降级处理）"
  exit 0
fi

case "$GRADE" in
  A|B)
    echo "✅ arch-check: $RESULT"
    exit 0
    ;;
  C)
    echo "⚠️  arch-check: $RESULT"
    echo ""
    echo "   架构 C 级 — 建议修复后再提交。"
    echo "   使用 --no-verify 跳过此检查: git commit --no-verify"
    echo "   查看详情: node lib/arch-check.mjs"
    exit 0  # C 级不阻断，仅警告
    ;;
  D)
    echo "🚫 arch-check: $RESULT"
    echo ""
    echo "   架构 D 级 — 提交被阻断。请修复失败维度后再提交。"
    echo ""
    echo "   查看详情:    node lib/arch-check.mjs"
    echo "   修复建议:    node lib/arch-check.mjs --fix-dry-run"
    echo "   紧急跳过:    git commit --no-verify"
    exit 1
    ;;
esac
