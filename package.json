    "test:coverage": "vitest run --coverage",
    "test:legacy": "node skills/rui/tests/run.mjs",
    "version": "node -e \"console.log(require('./package.json').version)\""
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@vitest/ui": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
