{
  "name": "yry",
  "version": "5.4.0",
  "private": true,
  "type": "module",
  "description": "YrY — story-driven SDLC orchestrator (Claude Code plugin)",
  "scripts": {
    "test": "vitest run",
    "test:all": "vitest run && node skills/rui/tests/run.mjs",
    "test:watch": "vitest",
