{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yry.dev/schemas/config-api.json",
  "title": "YrY Config API Schema",
  "description": "Formal schema for SKILL.md and agent .md frontmatter validation. Mirrors rules/architecture-principles.md §配置 API 规范.",

  "definitions": {
    "skillFrontmatter": {
      "type": "object",
      "required": ["name", "description", "user_invocable", "lifecycle"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "全局唯一标识，kebab-case，与目录名一致"
        },
        "description": {
          "type": "string",
          "maxLength": 120,
          "description": "一句话能力描述。SRP: 不含'和/与/也/并/及/以及/并且'"
        },
        "user_invocable": {
          "type": "boolean",
          "description": "用户是否可直接通过 /<name> 调用"
        },
        "lifecycle": {
          "type": "string",
          "enum": ["default-pipeline", "standalone", "background"],
          "description": "技能生命周期类型"
        },
        "agents": {
          "type": "object",
          "properties": {
            "required": {
              "type": "array",
              "items": { "type": "string" },
              "description": "必须参与的 agent 名列表"
            },
            "optional": {
              "type": "array",
              "items": { "type": "string" },
              "description": "可选参与的 agent 名列表"
            }
          },
          "additionalProperties": false
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "语义化版本号 semver"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "依赖的其他 skill name 列表"
        }
      },
      "additionalProperties": true
    },

    "agentFrontmatter": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "全局唯一标识，与文件名一致"
        },
        "description": {
          "type": "string",
          "maxLength": 120,
          "description": "一句话角色描述，描述决策视角（非执行动作）"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Read", "Grep", "Glob", "Edit", "Write", "Bash"]
          },
          "description": "允许的工具集（最小化原则）。见 rules/design-principles.md §ISP"
        },
        "triggers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "触发条件列表，可被下游验证"
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "产出物类型列表，可被下游检查"
        },
        "contract": {
          "type": "string",
          "description": "交接契约文件路径，指向 agents/ 下的文件"
        }
      },
      "additionalProperties": true
    },

    "ruleFrontmatter": {
      "type": "object",
      "required": ["paths"],
      "properties": {
        "paths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "适用范围 glob 模式。至少一个模式"
        }
      },
      "additionalProperties": true
    }
  },

  "validationRules": {
    "skillConstraints": {
      "directoryStructure": {
        "description": "skills/<name>/ 下必须包含 SKILL.md",
        "check": "existsSync('skills/<name>/SKILL.md')"
      },
      "nameMatchesDir": {
        "description": "frontmatter name 必须与目录名一致",
        "check": "fm.name === dirName"
      },
      "srpDescription": {
        "description": "description 不含并列连词",
        "check": "!/和|与|也|并|及|以及|并且/.test(fm.description)"
      }
    },
    "agentConstraints": {
      "nameMatchesFile": {
        "description": "frontmatter name 必须与文件名（不含 .md）一致",
        "check": "fm.name === fileName.replace('.md', '')"
      },
      "toolsMinimal": {
        "description": "工具集不超过职责必需的 1.5 倍",
        "check": "tools.length <= expectedMin * 1.5"
      }
    }
  }
}
