# YrY CDN — npm 包发布忽略清单
# 对应场景文档:
#   - 故事任务面板/yry-breadcrumb/场景-5-测试与发布/

# === Build / development files (npm 不应包含) ===
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc

# === Scripts (本地工程化,非运行时) ===
scripts/

# === CI / hooks ===
.github/

# === Lint / Format 配置 ===
.eslintrc*
eslint.config.*
.prettierrc*
.prettierignore
.stylelintrc*
.stylelintignore
.editorconfig
.gitattributes

# === Test files ===
tests/
test/
*.test.js
*.test.mjs
coverage/

# === Local dev artifacts ===
.env
.env.*
*.log
*.tmp
.DS_Store

# === Project governance (在仓库里读,不进 npm) ===
CONTRIBUTING.md
SECURITY.md
CLAUDE.md
docs/

# === Source meta / debug (源码仓库保留,npm 不需要) ===
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db