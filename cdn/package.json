{
  "name": "yry-cdn",
  "version": "1.2.0",
  "description": "YrY CDN — 125 shared frontend components: 30 Vue 3 custom elements + 83 Vanilla JS/Web Components + 12 page/style base classes. Dual theme system, 14 design tokens, 9 JS utility APIs, self-hosted JetBrains Mono fonts",
  "license": "MIT",
  "author": "effiyichengliang",
  "homepage": "https://github.com/effiyichengliang/YrY/tree/main/cdn#readme",
  "bugs": {
    "url": "https://github.com/effiyichengliang/YrY/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effiyichengliang/YrY.git",
    "directory": "cdn"
  },
  "keywords": [
    "yry",
    "cdn",
    "css",
    "theme",
    "mono",
    "frontend",
    "utility",
    "vue3",
    "custom-element",
    "design-tokens"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "shared/index.js",
  "style": "shared/index.css",
  "browser": "shared/index.js",
  "unpkg": "shared/index.js",
  "jsdelivr": "shared/index.js",
  "sideEffects": [
    "tokens/index.css",
    "*.css",
    "shared/index.js",
    "shared-reports/index.js",
    "yry-*/index.css",
    "yry-*/index.js",
    "js/*.js"
  ],
  "exports": {
    ".": {
      "style": "./shared/index.css",
      "default": "./shared/index.js"
    },
    "./shared.css": "./shared/index.css",
    "./shared.js": "./shared/index.js",
    "./tokens.css": "./tokens/index.css",
    "./theme.css": "./theme/index.css",
    "./theme-mono.css": "./theme-mono/index.css",
    "./fonts.css": "./fonts/index.css",
    "./fonts/*": "./fonts/*",
    "./shared-reports.css": "./shared-reports/index.css",
    "./shared-reports.js": "./shared-reports/index.js",
    "./*": "./*"
  },
  "files": [
    "tokens/index.css",
    "shared/index.css",
    "shared/index.js",
    "shared-reports/index.css",
    "shared-reports/index.js",
    "theme/index.css",
    "theme-mono/index.css",
    "fonts/index.css",
    "fonts/",
    "yry-*/index.html",
    "yry-*/index.js",
    "yry-*/index.css",
    "js/",
    "README.md",
    "CHANGELOG.md",
    "components-manifest/index.json",
    "changelog/index.json",
    "cdn-summary/index.json"
  ],
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint \"**/*.js\" --max-warnings 0",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "format": "prettier --write \"**/*.{js,mjs,json,md,css,html}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md,css,html}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "build:manifest": "node scripts/build-manifest.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "validate": "node scripts/validate.mjs",
    "validate:manifest": "node scripts/validate.mjs --only=manifest",
    "validate:version": "node scripts/validate.mjs --only=version",
    "validate:components": "node scripts/validate.mjs --only=components",
    "ci": "npm run lint && npm run validate && npm run build:manifest && npm run validate:manifest && npm run test",
    "self-check": "node scripts/dev-check.mjs",
    "prepublishOnly": "npm run validate && npm run build:manifest && npm run validate:manifest",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:stats": "node scripts/test-stats.mjs",
    "version": "node scripts/sync-version.mjs --bump && git add -A package.json README.md index.html CHANGELOG.md changelog/index.json components-manifest/index.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.13.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.3.3",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "vitest": "^3.2.4",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  }
}
